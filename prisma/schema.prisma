generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Registration {
  id            String   @id @default(cuid())
  email         String
  name          String
  company       String?
  createdAt     DateTime @default(now())
  downloadToken String   @unique
}
