# Database (required for registration)
# For Render.com: Add PostgreSQL from dashboard, DATABASE_URL is auto-set
# For local: Use a PostgreSQL connection string or create free DB at neon.tech / supabase
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# Optional: App URL for download links (Render sets RENDER_EXTERNAL_URL automatically)
# NEXT_PUBLIC_APP_URL="https://your-app.onrender.com"

# Cal.com scheduling (create free account at cal.com, get your link e.g. username/30min)
# NEXT_PUBLIC_CALCOM_LINK="vikramsankhala/30min"
